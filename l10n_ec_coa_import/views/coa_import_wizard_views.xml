<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_l10n_ec_coa_import_wizard" model="ir.ui.view">
        <field name="name">l10n.ec.coa.import.wizard.form</field>
        <field name="model">l10n.ec.coa.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Ecuadorian COA" class="o_form_readonly">
                <sheet>
                    <group>
                        <field name="company_id" readonly="state != 'upload'"/>
                        <field name="state" readonly="1" widget="statusbar" statusbar_visible="upload,review,configure,done"/>
                    </group>
                    <separator string="Upload Template" invisible="state != 'upload'"/>
                    <group invisible="state != 'upload'" colspan="2">
                        <field name="data_file" filename="data_filename"/>
                        <field name="data_filename" readonly="1"/>
                        <button name="action_download_template"
                                string="Download Template"
                                type="object"
                                class="btn btn-secondary mt16"/>
                    </group>
                    <separator string="Review" invisible="state != 'review'"/>
                    <group invisible="state != 'review'" colspan="2">
                        <field name="summary_message" nolabel="1" readonly="1" widget="text"/>
                        <field name="warning_message" nolabel="1" readonly="1" widget="text"/>
                        <field name="account_preview" nolabel="1" readonly="1" widget="text" class="oe_inline"/>
                        <field name="force_override"/>
                    </group>
                    <separator string="Configuration" invisible="state != 'configure'"/>
                    <group invisible="state != 'configure'" colspan="2">
                        <field name="summary_message" readonly="1"/>
                        <field name="generated_template_id" readonly="1"/>
                        <field name="default_receivable_account_id"/>
                        <field name="default_payable_account_id"/>
                        <field name="default_tax_sale_id"/>
                        <field name="default_tax_purchase_id"/>
                    </group>
                    <group invisible="state != 'done'" colspan="2">
                        <field name="summary_message" readonly="1"/>
                        <field name="generated_template_id" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                    <button name="action_parse_file" string="Validate Template" type="object" class="btn-primary" invisible="state != 'upload'"></button>
                    <button name="action_import" string="Import Data" type="object" class="btn-primary" invisible="state != 'review'"></button>
                    <button name="action_apply_configuration" string="Apply Defaults" type="object" class="btn-primary" invisible="state != 'configure'"></button>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_l10n_ec_coa_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Ecuadorian COA</field>
        <field name="res_model">l10n.ec.coa.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_l10n_ec_coa_import_wizard"/>
        <field name="target">new</field>
    </record>
</odoo>
