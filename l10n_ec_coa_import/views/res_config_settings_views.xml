<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_l10n_ec_coa_import" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.l10n.ec.coa.import</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='fiscal_localization_setting_container']/setting/div[hasclass('content-group')]" position="inside">
                <div class="mt16 d-flex flex-column flex-md-row gap-2">
                    <button name="action_open_l10n_ec_coa_import_wizard"
                            type="object"
                            string="Import Custom COA"
                            class="btn btn-primary"/>
                    <button name="%(action_download_coa_template)d"
                            type="action"
                            string="Download COA Template"
                            class="btn btn-secondary"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
