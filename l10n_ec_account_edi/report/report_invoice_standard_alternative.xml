<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="report_invoice_document_standard_alternative" inherit_id="account.report_invoice_document">
        <xpath expr="//t[@t-set='layout_document_title']" position="replace">
            <t t-if="o._l10n_ec_use_alternative_invoice_print_format()" t-set="layout_document_title">
                <span t-if="o.name and o.name != '/'" t-field="o.name" />
                <span t-else="" t-field="o.display_name" />
            </t>
            <t t-else="" t-set="layout_document_title">
                <span t-if="not proforma"></span>
                <span t-else="">PROFORMA</span>
                <span t-if="o.move_type == 'out_invoice' and o.state == 'posted'">Invoice</span>
                <span t-elif="o.move_type == 'out_invoice' and o.state == 'draft'">Draft Invoice</span>
                <span t-elif="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
                <span t-elif="o.move_type == 'out_refund' and o.state == 'posted'">Credit Note</span>
                <span t-elif="o.move_type == 'out_refund' and o.state == 'draft'">Draft Credit Note</span>
                <span t-elif="o.move_type == 'out_refund' and o.state == 'cancel'">Cancelled Credit Note</span>
                <span t-elif="o.move_type == 'in_refund'">Vendor Credit Note</span>
                <span t-elif="o.move_type == 'in_invoice'">Vendor Bill</span>
                <span t-if="o.name and o.name != '/'" t-field="o.name">INV/2023/0001</span>
            </t>
        </xpath>
        <xpath expr="//div[@name='invoice_date']/t[@t-if=&quot;o.move_type == 'out_invoice'&quot;]" position="replace">
            <t t-if="o.move_type == 'out_invoice' and o._l10n_ec_use_alternative_invoice_print_format()">
                <strong>Fecha de emision</strong>
            </t>
            <t t-elif="o.move_type == 'out_invoice'">
                <strong>Invoice Date</strong>
            </t>
        </xpath>
        <xpath expr="//div[@name='due_date']" position="replace">
        </xpath>
        <xpath expr="//div[@name='address_not_same_as_shipping']//address[@class='mb-0']" position="replace">
            <strong>Nombre del cliente</strong>
            <br/>
            <div t-field="o.partner_id.name"/>
            <strong>Dirección</strong>
            <br/>
            <address class="mb-0" t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
        </xpath>
        <xpath expr="//div[@name='address_same_as_shipping']//address[@class='mb-0']" position="replace">
            <strong>Nombre del cliente</strong>
            <br/>
            <div t-field="o.partner_id.name"/>
            <strong>Dirección</strong>
            <br/>
            <address class="mb-0" t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
        </xpath>
        <xpath expr="//div[@name='no_shipping']//address[@class='mb-0']" position="replace">
            <strong>Nombre del cliente</strong>
            <br/>
            <div t-field="o.partner_id.name"/>
            <strong>Dirección</strong>
            <br/>
            <address class="mb-0" t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
        </xpath>
        <xpath expr="//div[@t-if=&quot;o.move_type in ('out_invoice', 'in_refund') and o.payment_reference&quot;]" position="replace">
        </xpath>
    </template>
</odoo>