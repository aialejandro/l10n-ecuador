<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- Standalone withholding report template to avoid inheritance issues -->
    <template id="report_withhold_document_standalone_ec">
        <t t-set="o" t-value="o.with_context(lang=lang)" />
        <!-- Multicompany -->
        <t t-if="o and 'company_id' in o">
            <t t-set="company" t-value="o.company_id.sudo()" />
        </t>
        <t t-if="not o or not 'company_id' in o">
            <t t-set="company" t-value="res_company" />
        </t>
        <t t-set="partner" t-value="o.commercial_partner_id" />
        <t t-set="document_string" t-value="o.l10n_latam_document_type_id.report_name" />
        <t t-set="document_number" t-value="o.l10n_latam_document_number" />
        <t t-set="document_date" t-value="o.invoice_date" />
        <t
            t-set="edi_doc"
            t-value="o.edi_document_ids.filtered(lambda x: x.edi_format_id.code == 'l10n_ec_format_sri')"
        />
        <t t-set="emission_address" t-value="o.journal_id.l10n_ec_emission_address_id" />
        
        <div class="article" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
            <t t-call="l10n_ec_account_edi.electronic_report_common_head" />
            <t t-if="o.company_id.l10n_ec_retention_agent_caption">
                <div
                    class="mt-1"
                    style="font-size: 8px;"
                    t-esc="o.company_id.l10n_ec_retention_agent_caption"
                />
            </t>
            <!-- Withholding body -->
            <t t-call="l10n_ec_withhold.e_withhold_document_body" />
        </div>
    </template>

    <template
        id="report_withhold_document_ec"
        inherit_id="l10n_ec_account_edi.report_invoice_document"
        primary="True"
        priority="100"
    >
        <xpath
            expr='//t[@t-call="l10n_ec_account_edi.electronic_report_common_head"]'
            position="after"
        >
            <t t-if="o.l10n_latam_document_type_id.internal_type == 'withhold'">
                <t t-call="l10n_ec_withhold.e_withhold_document_body" />
            </t>
        </xpath>
        <!-- remove the total section because field tax_totals is None for entry-->
        <xpath
            expr='//t[@t-call="l10n_ec_account_edi.electronic_report_common_total_info"]'
            position="replace"
        />
    </template>

    <template id="report_withhold_ec">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.partner_id.lang" />
                <!-- Use standalone template for withholdings to avoid inheritance issues -->
                <t t-if="o.l10n_latam_document_type_id.internal_type == 'withhold'">
                    <t t-call="l10n_ec_withhold.report_withhold_document_standalone_ec" t-lang="lang" />
                </t>
                <t t-else="">
                    <t t-call="l10n_ec_withhold.report_withhold_document_ec" t-lang="lang" />
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_withholding_ec" model="ir.actions.report">
        <field name="name">Withholding EC</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_ec_withhold.report_withhold_ec</field>
        <field name="report_file">l10n_ec_withhold.report_withhold_ec</field>
        <field name="print_report_name">(object._get_report_base_filename())</field>
        <field name="attachment" />
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_type">report</field>
        <field name="is_invoice_report">True</field>
        <field
            name="groups_id"
            eval="[(4, ref('account.group_account_invoice')), (4, ref('account.group_account_readonly'))]"
        />
    </record>
</odoo>
