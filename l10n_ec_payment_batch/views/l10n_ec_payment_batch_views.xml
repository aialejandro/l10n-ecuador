<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Payment Batch Tree View -->
    <record id="view_l10n_ec_payment_batch_tree" model="ir.ui.view">
        <field name="name">l10n_ec.payment.batch.tree</field>
        <field name="model">l10n_ec.payment.batch</field>
        <field name="arch" type="xml">
            <list string="Payment Batches" decoration-info="state=='draft'" decoration-success="state=='confirmed'">
                <field name="name"/>
                <field name="batch_date"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="payment_method_line_id"/>
                <field name="total_amount" sum="Total"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="state" widget="badge" decoration-info="state=='draft'" decoration-success="state=='confirmed'" decoration-muted="state=='cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Payment Batch Form View -->
    <record id="view_l10n_ec_payment_batch_form" model="ir.ui.view">
        <field name="name">l10n_ec.payment.batch.form</field>
        <field name="model">l10n_ec.payment.batch</field>
        <field name="arch" type="xml">
            <form string="Payment Batch">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('draft', 'confirmed')"/>
                    <button name="action_download_txt" string="Download TXT" type="object" invisible="not line_ids"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Batch Name" required="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="batch_date"/>
                            <field name="partner_type"/>
                            <field name="payment_method_line_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="total_amount" widget="monetary"/>
                        </group>
                    </group>
                    <group>
                        <field name="partner_ids" widget="many2many_tags"/>
                    </group>
                    <group>
                        <field name="description" placeholder="This description will be used as memo in created payments..."/>
                    </group>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_payments" icon="fa-money" invisible="payment_count == 0">
                            <field string="Payments" name="payment_count" widget="statinfo"/>
                        </button>
                        <button name="action_update_lines" string="Update Lines" type="object" class="btn-primary" invisible="state != 'draft' or not partner_ids"/>
                    </div>
                    <notebook>
                        <page string="Payment Lines" name="lines">
                            <field name="line_ids" context="{'default_partner_id': partner_ids and partner_ids[0] or False}">
                                <list editable="bottom">
                                    <field name="partner_id"/>
                                    <field name="payment_method_line_id" optional='hide'/>
                                    <field name="is_own_checks" column_invisible="True"/>
                                    <field name="check_number" optional="show" column_invisible='not parent.has_own_checks'/>
                                    <field name="check_beneficiary" optional="show" column_invisible='not parent.has_own_checks'/>
                                    <field name="check_payment_date" optional="show" column_invisible='not parent.has_own_checks'/>
                                    <field name="reconcile_line_ids" widget="many2many_tags" readonly="1"/>
                                    <button name="action_open_reconcile_wizard" type="object" string="Select Invoices" class="btn-secondary" invisible="parent.state != 'draft'"/>
                                    <field name="full_residual" widget="monetary"/>
                                    <field name="amount" widget="monetary" readonly="reconcile_line_ids"/>
                                    <field name="currency_id" column_invisible="True"/>
                                    <field name="batch_id" column_invisible="True"/>
                                    <field name="tag_color" widget="color" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Payment Batch Search View -->
    <record id="view_l10n_ec_payment_batch_search" model="ir.ui.view">
        <field name="name">l10n_ec.payment.batch.search</field>
        <field name="model">l10n_ec.payment.batch</field>
        <field name="arch" type="xml">
            <search string="Payment Batches">
                <field name="name" string="Batch" filter_domain="[('name', 'ilike', self)]"/>
                <field name="payment_method_line_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <separator/>
                <filter string="Batch Date" name="batch_date" date="batch_date"/>
                <group expand="0" string="Group By">
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Batch Date" name="group_batch_date" context="{'group_by': 'batch_date'}"/>
                    <filter string="Payment Method" name="group_payment_method" context="{'group_by': 'payment_method_line_id'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Payment Batch Action -->
    <record id="action_l10n_ec_payment_batch" model="ir.actions.act_window">
        <field name="name">Payment Batches</field>
        <field name="res_model">l10n_ec.payment.batch</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_draft': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new payment batch
            </p>
            <p>
                Payment batches allow you to group multiple payments together for processing.
            </p>
        </field>
    </record>

    <!-- Action for Supplier Payments -->
    <record id="action_l10n_ec_payment_batch_supplier" model="ir.actions.act_window">
        <field name="name">Supplier Payment Batches</field>
        <field name="res_model">l10n_ec.payment.batch</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_draft': 1, 'default_partner_type': 'supplier'}</field>
        <field name="domain">[('partner_type', '=', 'supplier')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new supplier payment batch
            </p>
            <p>
                Payment batches allow you to group multiple supplier payments together for processing.
            </p>
        </field>
    </record>

    <!-- Action for Customer Payments -->
    <record id="action_l10n_ec_payment_batch_customer" model="ir.actions.act_window">
        <field name="name">Customer Payment Batches</field>
        <field name="res_model">l10n_ec.payment.batch</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_draft': 1, 'default_partner_type': 'customer'}</field>
        <field name="domain">[('partner_type', '=', 'customer')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new customer payment batch
            </p>
            <p>
                Payment batches allow you to group multiple customer payments together for processing.
            </p>
        </field>
    </record>

    <!-- Menu Items -->

    <menuitem id="menu_l10n_ec_payment_batch_supplier"
        name="Batch Payments"
        parent="account.menu_finance_payables"
        action="action_l10n_ec_payment_batch_supplier"
        sequence="50"/>

    <menuitem id="menu_l10n_ec_payment_batch_customer"
        name="Batch Payments"
        parent="account.menu_finance_receivables"
        action="action_l10n_ec_payment_batch_customer"
        sequence="39"/>

</odoo>
