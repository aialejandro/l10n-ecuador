<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Reconcile Wizard Form View -->
    <record id="view_l10n_ec_payment_batch_reconcile_wizard_form" model="ir.ui.view">
        <field name="name">l10n_ec.payment.batch.reconcile.wizard.form</field>
        <field name="model">l10n_ec.payment.batch.reconcile.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Invoices to Reconcile">
                <sheet>
                    <group>
                        <group>
                            <field name="batch_line_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="partner_type" readonly="1"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_selected" widget="monetary"/>
                        </group>
                    </group>
                    <group>
                        <button name="action_select_all" string="Select All" type="object" class="btn-primary"/>
                        <button name="action_deselect_all" string="Deselect All" type="object" class="btn-secondary"/>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom" decoration-success="selected" decoration-muted="available_residual == 0">
                            <field name="selected" widget="boolean_toggle"/>
                            <field name="move_id" readonly="1"/>
                            <field name="date_maturity" optional="show"/>
                            <field name="full_residual" widget="monetary" readonly="1"/>
                            <field name="allocated_in_batch" widget="monetary" readonly="1" optional="hide"/>
                            <field name="available_residual" widget="monetary" readonly="1"/>
                            <field name="amount" widget="monetary"/>
                            <field name="currency_id" column_invisible="True"/>
                            <field name="move_line_id" column_invisible="True"/>
                            <field name="batch_id" column_invisible="True"/>
                            <field name="batch_line_id" column_invisible="True"/>
                            <field name="wizard_id" column_invisible="True"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Reconcile Wizard Action -->
    <record id="action_l10n_ec_payment_batch_reconcile_wizard" model="ir.actions.act_window">
        <field name="name">Select Invoices</field>
        <field name="res_model">l10n_ec.payment.batch.reconcile.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_l10n_ec_payment_batch_line"/>
        <field name="binding_view_types">form</field>
    </record>

</odoo>
