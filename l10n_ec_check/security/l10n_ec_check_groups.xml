<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Grupo para gestión de formatos de cheque -->
        <record id="group_check_format_manager" model="res.groups">
            <field name="name">Gestor de Formatos de Cheque</field>
            <field name="category_id" ref="base.module_category_accounting"/>
            <field name="comment">Usuarios que pueden crear y modificar formatos de cheque</field>
        </record>
        
        <!-- Grupo para usuarios que solo pueden usar formatos existentes -->
        <record id="group_check_format_user" model="res.groups">
            <field name="name">Usuario de Formatos de Cheque</field>
            <field name="category_id" ref="base.module_category_accounting"/>
            <field name="comment">Usuarios que pueden usar formatos de cheque existentes</field>
            <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
        </record>
        
        <!-- Agregar gestores a usuarios contables -->
        <record id="account.group_account_manager" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_check_format_manager'))]"/>
        </record>
        
    </data>
</odoo>
