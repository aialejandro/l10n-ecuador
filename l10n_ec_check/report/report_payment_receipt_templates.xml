<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Heredar el template del recibo de pago para agregar información del cheque -->
    <template id="report_payment_receipt_document_ec_check" inherit_id="account.report_payment_receipt_document">
        
        <!-- Agregar información del cheque después de la fila que contiene el método de pago -->
        <xpath expr="//div[@name='payment_method']/.." position="after">
            <!-- Nueva fila para información del cheque -->
            <div class="row" t-if="o.payment_method_code == 'check_printing'">
                <!-- Banco -->
                <div class="col-6" t-if="o.journal_id.bank_id">
                    <strong>Banco:</strong> <span t-field="o.journal_id.bank_id.name"/>
                </div>
                
                <!-- Número de cheque -->
                <div class="col-6" t-if="o.l10n_ec_check_number">
                    <strong>Cheque No.:</strong> <span t-field="o.l10n_ec_check_number"/>
                </div>
            </div>
            
            <!-- Segunda fila para cuenta bancaria -->
            <div class="row" t-if="o.payment_method_code == 'check_printing' and o.journal_id.bank_account_id">
                <div class="col-6">
                    <strong>Cuenta Bancaria:</strong> <span t-field="o.journal_id.bank_account_id.acc_number"/>
                </div>
            </div>
        </xpath>
        
    </template>
    
</odoo>
