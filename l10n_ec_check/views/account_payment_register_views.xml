<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="l10n_ec_check_view_account_payment_register_form" model="ir.ui.view">
        <field name="name">account.payment.register.form.l10n_ec_check</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="l10n_latam_check.view_account_payment_register_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='l10n_latam_new_check_ids']//list/field[@name='name']" position="after">
                <field name="beneficiary" string="Beneficiario"/>
            </xpath>
            <xpath expr="//list[@name='existing_checks']/field[@name='name']" position="after">
                <field name="beneficiary" string="Beneficiario" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
