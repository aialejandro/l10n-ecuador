<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Heredar vista de formulario de pagos para agregar información de formato de cheque -->
    <record id="view_account_payment_form_check_format" model="ir.ui.view">
        <field name="name">account.payment.form.check.format</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
        <!-- Agregar botones en el header para cheques -->
        <xpath expr="//header" position="inside">
        <button name="action_print_check" type="object" string="Imprimir Cheque"
            class="btn-primary" icon="fa-print"
            invisible="payment_method_code != 'own_checks' or state not in ('in_process', 'paid') or not l10n_ec_single_check_available or l10n_ec_single_check_printed"
            help="Imprimir el cheque asociado a este pago."/>
        <button name="action_reset_check_printed" type="object" string="Resetear Impresión" 
            class="btn-warning" icon="fa-refresh"
            groups="base.group_system"
            invisible="payment_method_code != 'own_checks' or state not in ('in_process', 'paid') or not l10n_ec_single_check_available or not l10n_ec_single_check_printed"
            confirm="¿Está seguro que desea resetear el estado de impresión? Esto permitirá reimprimir los cheques."/>
        </xpath>
            <!-- Agregar botón de impresión por cheque y columnas de seguimiento -->
            <xpath expr="//list[@name='new_checks']/field[@name='name']" position="after">
                <field name="beneficiary" string="Beneficiario" optional="show"/>
            </xpath>
            <xpath expr="//list[@name='new_checks']/field[@name='amount']" position="after">
                <field name="check_printed" optional="hide"/>
                <field name="check_print_date" optional="hide"/>
                <field name="check_printed_by" optional="hide"/>
                <button name="action_l10n_ec_print_check"
                        type="object"
                        string="Imprimir"
                        icon="fa-print"
                        column_invisible="parent.payment_method_code != 'own_checks' or parent.state not in ('in_process', 'paid')"
                        help="Imprimir este cheque utilizando el formato configurado."/>
                <button name="action_l10n_ec_print_expense_voucher"
                    type="object"
                    string="Comp. de Egreso"
                    icon="fa-file-text-o"
                    column_invisible="parent.state not in ('posted', 'in_process', 'paid') or not parent.move_id"
                    help="Generar el comprobante de egreso para este cheque."/>
            </xpath>
        </field>
    </record>

    <!-- Heredar vista de búsqueda para agregar filtros relacionados con cheques -->
    <record id="view_account_payment_search_check_beneficiary" model="ir.ui.view">
        <field name="name">account.payment.search.check.beneficiary</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_search"/>
        <field name="arch" type="xml">
            <!-- Agregar filtro en el grupo de filtros -->
            <filter name="outbound_filter" position="after">
                <separator/>
        <filter string="Cheques Impresos" 
            name="filter_check_printed"
            domain="[('l10n_latam_new_check_ids.check_printed', '=', True), ('payment_method_code', '=', 'own_checks')]"/>
            </filter>
        </field>
    </record>

    <record id="l10n_ec_check_view_check_form_beneficiary" model="ir.ui.view">
        <field name="name">l10n_latam_check.view.form.beneficiary</field>
        <field name="model">l10n_latam.check</field>
        <field name="inherit_id" ref="l10n_latam_check.l10n_latam_check_view_form"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="partner_id"/>
                <field name="beneficiary" string="Beneficiary"/>
                  <field name="check_reprinted" string="Check Reprinted" readonly="1"
                      modifiers="{'invisible': [['check_reprinted', '=', False]]}"/>
            </field>
            <field name="payment_date" position="before">
                <field name="date" string="Issue Date"/>
            </field>
            <field name="amount" position="before">
                <field name="payment_id" optional="show"/>
                <field name="payment_ref" optional="show"/>
            </field>
        </field>
    </record>

    <record id="l10n_ec_check_view_check_tree_beneficiary" model="ir.ui.view">
        <field name="name">l10n_latam_check.view.tree.beneficiary</field>
        <field name="model">l10n_latam.check</field>
        <field name="inherit_id" ref="l10n_latam_check.view_account_own_check_tree"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="beneficiary" string="Beneficiary" optional="show"/>
            </field>
            <field name="payment_date" position="before">
                <field name="date" string="Issue Date" optional="show"/>
            </field>
            <field name="original_journal_id" position="after">
                <field name="payment_id" optional="show"/>
                <field name="payment_ref" optional="show"/>
            </field>
        </field>
    </record>


</odoo>
