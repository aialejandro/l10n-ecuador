<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Heredar vista de formulario de pagos para agregar información de formato de cheque -->
    <record id="view_account_payment_form_check_format" model="ir.ui.view">
        <field name="name">account.payment.form.check.format</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <!-- Agregar botones en el header para cheques -->
            <xpath expr="//header" position="inside">
                <button name="action_print_checks" type="object" string="Imprimir Cheque" 
                        class="btn-primary" icon="fa-print"
                        invisible="can_print_check == False"/>
                <button name="action_preview_check" type="object" string="Previsualizar Cheque" 
                        class="btn-secondary" icon="fa-eye"
                        invisible="can_print_check == False"/>
            </xpath>
            
            <!-- Mostrar información del formato de cheque -->
            <xpath expr="//field[@name='payment_method_line_id']" position="after">
                <field name="l10n_ec_check_format_id" readonly="1"
                       invisible="payment_method_code != 'check_printing'"/>
                <field name="can_print_check" invisible="1"/>
            </xpath>
        </field>
    </record>

    <!-- Heredar vista de lista de pagos para agregar información de formato -->
    <record id="view_account_payment_tree_check_format" model="ir.ui.view">
        <field name="name">account.payment.tree.check.format</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="l10n_ec_check_format_id" string="Formato de Cheque" optional="hide"/>
                <field name="can_print_check" invisible="1"/>
            </xpath>
        </field>
    </record>

