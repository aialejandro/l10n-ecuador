<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Vista de formulario para el wizard de reseteo -->
    <record id="view_l10n_ec_check_reset_wizard_form" model="ir.ui.view">
        <field name="name">l10n_ec.check.reset.wizard.form</field>
        <field name="model">l10n_ec.check.reset.wizard</field>
        <field name="arch" type="xml">
            <form string="Reset Checks Print Status">
                <group>
                    <div class="alert alert-warning" role="alert" style="margin-bottom: 16px;">
                        <i class="fa fa-exclamation-triangle" title="Warning"/> 
                        <strong>Warning</strong>
                        <field name="reset_warning_html" nolabel="1" readonly="1" widget="html"/>
                        <p style="margin-top: 8px; margin-bottom: 0;">
                            Assigned check numbers are kept to avoid duplicates and the action is logged in the chatter.
                        </p>
                    </div>
                </group>
                
                <group>
                    <field name="check_details" nolabel="1" colspan="2"/>
                </group>
                
                <separator string="Security Validation"/>
                
                <group>
                    <div class="alert alert-info d-flex align-items-center" role="alert" style="margin-bottom: 16px;">
                        <i class="fa fa-lock me-2" title="Security"/>
                        <div>Enter your password to confirm this action.</div>
                    </div>
                </group>
                
                <group>
                    <field name="password" password="True" placeholder="Enter your password" required="1"/>
                    <field name="check_ids" invisible="1"/>
                </group>
                
                <footer>
                    <button name="action_confirm_reset" 
                            string="Confirm Reset" 
                            type="object" 
                            class="btn-primary"
                            icon="fa-check"/>
                    <button string="Cancel" 
                            special="cancel" 
                            class="btn-secondary"
                            icon="fa-times"/>
                </footer>
            </form>
        </field>
    </record>
    
</odoo>
